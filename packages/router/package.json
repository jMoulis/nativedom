{
  "name": "@nativedom/router",
  "version": "0.1.1",
  "description": "Signal-backed client-side router for NativeDOM",
  "keywords": [
    "web-components",
    "router",
    "signals",
    "spa",
    "history-api"
  ],
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@nativedom/core": ">=0.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
