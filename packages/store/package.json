{
  "name": "@nativeframe/store",
  "version": "0.1.0",
  "description": "Reactive global store with SSR snapshot/rehydration for NativeFrame",
  "keywords": ["web-components", "signals", "store", "ssr", "reactive"],
  "license": "MIT",
  "type": "module",
  "exports": { ".": "./src/index.ts" },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@nativeframe/core": ">=0.1.0"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  }
}
