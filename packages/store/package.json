{
  "name": "@nativedom/store",
  "version": "0.1.1",
  "description": "Reactive global store with SSR snapshot/rehydration for NativeFrame",
  "keywords": [
    "web-components",
    "signals",
    "store",
    "ssr",
    "reactive"
  ],
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@nativedom/core": ">=0.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
