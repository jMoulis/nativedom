{
  "name": "@nativeframe/server",
  "version": "0.1.0",
  "description": "Server-side rendering and streaming for NativeFrame components",
  "keywords": ["web-components", "ssr", "streaming", "server-rendering"],
  "license": "MIT",
  "type": "module",
  "exports": { ".": "./src/renderer.ts" },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@nativeframe/core": ">=0.1.0"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  }
}
